{
  "background_color": "#000e25",
  "categories": ["games", "travel"],
  "display": "standalone",
  "icons": [
    {
      "purpose": "any",
      "sizes": "any",
      "src": "compass-icon-fit.svg",
      "type": "image/svg"
    },
    {
      "purpose": "maskable",
      "sizes": "any",
      "src": "compass-icon-circled.svg",
      "type": "image/svg"
    },
    {
      "purpose": "monochrome",
      "sizes": "any",
      "src": "compass-icon-monochrome.svg",
      "type": "image/svg"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "archipelago",
      "url": "?connecturl=%s"
    },
    {
      "protocol": "web+archipelago",
      "url": "?connecturl=%s"
    }
  ],
  "start_url": "index.html#connect",
  "theme_color": "lightsteelblue"
}
