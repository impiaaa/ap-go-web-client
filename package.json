{
  "dependencies": {
    "archipelago.js": "^2.1.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "loc-i18next": "^0.1.6",
    "maplibre-gl": "^5.24.0",
    "pure-rand": "^8.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@poupe/material-color-utilities": "^0.4.1",
    "@rsbuild/core": "^2.0.10",
    "@rsbuild/plugin-type-check": "^1.3.5",
    "@types/color-rgba": "^2.1.3",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "color-rgba": "^3.0.0",
    "i18next-cli": "^1.59.1",
    "jsdom": "^29.1.1",
    "rsbuild-plugin-html-minifier-terser": "^1.1.4",
    "rsbuild-plugin-i18next-extractor": "^0.2.1",
    "rsbuild-plugin-wasmpack": "^2.0.0",
    "smol-toml": "^1.6.1",
    "svgo": "^4.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "license": "AGPL-3.0-only",
  "name": "ap-go-web-client",
  "private": true,
  "scripts": {
    "build": "rsbuild build",
    "check": "biome check --write ; sed -i'' 's/< %=/<%=/g' src/index.html",
    "ci": "biome ci --html-formatter-enabled=false --html-linter-enabled=false --html-assist-enabled=false && cd gen && cargo fmt --check && cargo check",
    "dev": "rsbuild dev --open",
    "format": "biome format --write ; sed -i'' 's/< %=/<%=/g' src/index.html",
    "preview": "rsbuild preview",
    "zip": "ASSET_PREFIX=./ rsbuild build; cd dist; zip -r ../ap-go-web-client-$(git describe --always --dirty='*' --tags).zip ./"
  },
  "type": "module",
  "version": "0.0.1"
}
